# Base URL for the CineConnectKE REST API (backend/, PORT=5000 by default).
# Leave this UNSET/commented out in dev — src/services/api.ts auto-detects
# your computer's LAN IP from the Expo bundler host, which is what a physical
# phone needs (it can't reach "localhost", that's the phone itself).
# Uncomment and set explicitly only to point at a non-local server (staging, etc.):
# EXPO_PUBLIC_API_URL=http://192.168.1.42:5000

# Socket.io server URL for real-time chat. Leave unset to reuse the same
# auto-detected host as the REST API above.
# EXPO_PUBLIC_SOCKET_URL=http://192.168.1.42:5000

# Legacy flag from early development, when screens were powered by a bundled
# mock dataset. Every domain (auth, dashboard, jobs, applications,
# notifications, admin, messaging, user discovery) has since been wired to
# the live backend unconditionally — this flag is no longer read anywhere
# in src/api/*. Kept only so it doesn't break existing .env files; see
# README.md's Project Progress section.
EXPO_PUBLIC_USE_MOCK=true
